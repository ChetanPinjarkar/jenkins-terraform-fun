pipeline {
    agent any

    parameters {
        choice(
            name: 'action', 
            choices: ['apply', 'destroy'], 
            description: 'Choose the terraform action to perform'
            )
    }

    stages {
        stage('Checkout') {
            steps {
                git branch: 'main',
                url: 'https://github.com/ChetanPinjarkar/jenkins-terraform-fun.git'
            }
        }
        stage('Terraform init') {
            steps {
                dir('vm_provision') {
                    sh 'terraform init'                
                }
            }
        }
        stage('Terraform validate') {
            steps {
                dir('vm_provision') {
                    sh 'terraform validate'
                }
            }
        }
        stage('Terraform Plan') {
            steps {
                dir('vm_provision') {
                    sh 'terraform plan -out=tfplan'
                }
            }
        }
        stage('Terraform Apply or Destroy') {
            steps {
                dir('vm_provision') {
                    sh "terraform ${params.action} -auto-approve tfplan"
                }
            }
        }
    }
}